---
import BaseLayout from '../layouts/BaseLayout.astro';
import { thoughts } from '../data/thoughts';
import LinkDisplay from '../components/LinkDisplay.astro';
---
<BaseLayout 
  title="Thinking" 
  description="A digital garden of abstract thoughts, philosophical inquiries, and notes on patterns I've observed."
>
  <main class="max-w-3xl mx-auto px-6 md:px-8 pt-16 md:pt-20 pb-24">
    
    <!-- Hero -->
    <header class="mb-20 md:mb-24">
      <div class="flex items-center gap-4 mb-6 md:mb-8">
        <div class="w-8 md:w-12 h-px bg-orange-900/30"></div>
        <span class="text-[10px] md:text-xs uppercase tracking-[0.3em] text-orange-900/60 font-sans font-semibold">Fragments of thought —</span>
      </div>
      <h1 class="text-4xl sm:text-5xl md:text-7xl text-stone-900 font-serif leading-[1.1] tracking-tight mb-8 md:mb-10">
        Thinking <br />
        <span class="text-orange-900/80 italic font-light">Explorations of the abstract.</span>
      </h1>
      <p class="text-stone-500 max-w-lg leading-relaxed font-sans text-base">
        Notes on philosophy, logic, and the structures underneath. 
        A digital garden for ideas that aren't code, but define it.
      </p>
    </header>

    <!-- Thought List -->
    <div class="space-y-10 md:space-y-12">
      {thoughts.map((thought) => (
        <article class="soft-block group/article">
          <div class="flex flex-col md:flex-row gap-6 md:gap-8">
            <div class="w-auto md:w-24 shrink-0 flex flex-row md:flex-col items-center md:items-start gap-4 md:gap-2">
              <span class="text-[9px] md:text-[10px] tracking-widest text-orange-900/40 font-sans font-bold group-hover/article:text-orange-900/80 transition-colors duration-500 whitespace-nowrap">{thought.date}</span>
              <div class="flex items-center gap-2 text-[9px] uppercase tracking-widest text-stone-400 font-sans font-bold">
                <thought.icon class="w-3 h-3" />
                {thought.category}
              </div>
            </div>
            
            <div class="flex-1">
              <div class="flex items-start justify-between mb-4">
                <h2 class="text-2xl text-stone-900 font-serif group-hover/article:translate-x-1 transition-transform duration-500">{thought.title}</h2>
                <LinkDisplay id={thought.id} />
              </div>
              <p class="text-stone-600 leading-relaxed max-w-xl italic font-serif text-lg opacity-80">
                "{thought.description}"
              </p>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Footer Note -->
    <footer class="mt-24 pt-16 border-t border-stone-200/40">
      <p class="text-sm text-stone-400 italic font-serif">
        Building my own personalized agent with these fragments.
      </p>
    </footer>
  </main>
</BaseLayout>