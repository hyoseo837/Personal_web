---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ExternalLink, Github } from 'lucide-astro';
import { projects } from '../data/projects';
---
<BaseLayout title="Projects">
  <main class="max-w-3xl mx-auto px-8 pt-20 pb-24">
    
    <!-- Hero -->
    <header class="mb-24">
      <div class="flex items-center gap-4 mb-8">
        <div class="w-12 h-px bg-orange-900/30"></div>
        <span class="text-xs uppercase tracking-[0.3em] text-orange-900/60 font-sans font-semibold">Artifacts of my learning —</span>
      </div>
      <h1 class="text-5xl md:text-7xl text-stone-900 font-serif leading-[1.1] tracking-tight mb-10">
        Projects <br />
        <span class="text-orange-900/80 italic font-light">Evidence of exploration.</span>
      </h1>
      <p class="text-stone-500 max-w-lg leading-relaxed font-sans">
        From my first infection simulation in 10th grade to full-stack architectures. 
        A comprehensive log of my journey through physics, data, and software.
      </p>
    </header>

    <!-- Project List -->
    <div class="space-y-12">
      {projects.map((project) => (
        <section class="soft-block group/project">
          <div class="flex flex-col md:flex-row gap-8">
            <div class="w-16 shrink-0">
              <div class="p-3 bg-orange-900/5 rounded-xl group-hover/project:bg-orange-900/10 transition-colors inline-block">
                <project.icon class="w-6 h-6 text-orange-900/60" />
              </div>
            </div>
            
            <div class="flex-1">
              <div class="flex items-center justify-between mb-4">
                <h2 class="text-2xl text-stone-900 font-serif group-hover/project:translate-x-1 transition-transform duration-500">{project.title}</h2>
                <div class="flex gap-4">
                  {project.github && (
                    <a href={project.github} target="_blank" rel="noopener noreferrer" class="text-stone-400 hover:text-orange-900 transition-colors p-1">
                      <Github class="w-4 h-4" />
                    </a>
                  )}
                  {project.link && (
                    <a href={project.link} target="_blank" rel="noopener noreferrer" class="text-stone-400 hover:text-orange-900 transition-colors p-1">
                      <ExternalLink class="w-4 h-4" />
                    </a>
                  )}
                </div>
              </div>
              
              <div class="text-[10px] uppercase tracking-widest text-orange-900/50 font-sans font-bold mb-6 group-hover/project:text-orange-900/80 transition-colors">
                {project.stack}
              </div>
              
              <p class="text-stone-600 leading-relaxed max-w-xl font-sans opacity-90">
                {project.description}
              </p>
            </div>
          </div>
        </section>
      ))}
    </div>

    <!-- Footer Note -->
    <footer class="mt-24 pt-16 border-t border-stone-200/40">
      <p class="text-sm text-stone-400 italic font-serif">
        And many more minor experiments in Python, JS, and Dart.
      </p>
    </footer>
  </main>
</BaseLayout>