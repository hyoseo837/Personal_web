---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/projects';
import { thoughts } from '../data/thoughts';
import { tastes } from '../data/tastes';
import { links } from '../data/links';

// Prepare nodes
const nodes = [
  ...thoughts.map(t => ({ 
    id: t.id, 
    name: t.title, 
    type: 'thought', 
    desc: t.description, 
    sub: t.category, 
    meta: t.date 
  })),
  ...projects.map(p => ({ 
    id: p.id, 
    name: p.title, 
    type: 'project', 
    desc: p.description, 
    sub: p.stack 
  })),
  ...tastes.map(t => ({ 
    id: t.id, 
    name: t.name, 
    type: 'taste', 
    desc: t.description, 
    sub: t.category, 
    meta: t.creator,
    pid: t.pid
  }))
];

const graphLinks = links.map(l => ({
  source: l.from,
  target: l.to,
  reason: l.reason
}));

tastes.forEach(taste => {
  if (taste.connections) {
    taste.connections.forEach(connName => {
      const target = tastes.find(t => t.name === connName);
      if (target) {
        const exists = graphLinks.some(l => 
          (l.source === taste.id && l.target === target.id) || 
          (l.source === target.id && l.target === taste.id)
        );
        if (!exists) {
          graphLinks.push({
            source: taste.id,
            target: target.id,
            reason: 'Shared taste'
          });
        }
      }
    });
  }
});

const data = { nodes, links: graphLinks };
---

<BaseLayout title="Mind Graph">
  <main class="w-full h-[calc(100vh-80px)] relative overflow-hidden bg-stone-50">
    
    <!-- Header Info -->
    <div class="absolute top-12 left-12 z-10 pointer-events-none">
      <div class="flex items-center gap-4 mb-4">
        <div class="w-12 h-px bg-orange-900/30"></div>
        <span class="text-xs uppercase tracking-[0.3em] text-orange-900/60 font-sans font-semibold">The Pattern Web —</span>
      </div>
      <h1 class="text-4xl text-stone-900 font-serif tracking-tight">Mind Graph</h1>
    </div>

    <!-- Detail Panel (Right Side) -->
    <div 
      id="detail-panel" 
      class="absolute top-12 right-12 z-20 w-80 translate-x-12 opacity-0 pointer-events-none transition-all duration-500 ease-out"
    >
      <div class="bg-stone-900/90 backdrop-blur-xl p-8 rounded-[2.5rem] border border-white/10 shadow-2xl overflow-hidden relative group">
        <div id="pokemon-bg" class="absolute -right-4 -bottom-4 opacity-10 pointer-events-none grayscale brightness-200"></div>

        <div id="panel-type" class="text-[10px] uppercase tracking-[0.3em] text-orange-400 font-sans font-bold mb-4"></div>
        
        <div id="pokemon-container" class="hidden justify-center mb-6">
          <img id="pokemon-img" src="" alt="" class="w-32 h-32 pixelated drop-shadow-[0_0_15px_rgba(255,255,255,0.2)]" />
        </div>

        <h2 id="panel-title" class="text-2xl text-white font-serif leading-tight mb-4 tracking-tight"></h2>
        <div id="panel-sub" class="text-[10px] uppercase tracking-widest text-stone-400 font-sans font-bold mb-6 pb-6 border-b border-white/5"></div>
        <p id="panel-desc" class="text-stone-300 font-serif italic text-lg leading-relaxed"></p>
        
        <div id="panel-meta" class="mt-8 text-[9px] uppercase tracking-widest text-stone-500 font-sans font-bold"></div>
      </div>
    </div>

    <!-- Legend -->
    <div class="absolute bottom-12 left-12 z-10 bg-white/50 backdrop-blur-md p-6 rounded-3xl border border-stone-200/50 shadow-sm">
      <div class="flex flex-col gap-4">
        <div class="flex items-center gap-3">
          <div class="w-3 h-3 rounded-full bg-orange-600 shadow-[0_0_10px_rgba(234,88,12,0.4)]"></div>
          <span class="text-[10px] uppercase tracking-widest font-sans font-bold text-stone-600">Thoughts</span>
        </div>
        <div class="flex items-center gap-3">
          <div class="w-3 h-3 rounded-full bg-stone-800 shadow-[0_0_10px_rgba(28,25,23,0.3)]"></div>
          <span class="text-[10px] uppercase tracking-widest font-sans font-bold text-stone-600">Projects</span>
        </div>
        <div class="flex items-center gap-3">
          <div class="w-3 h-3 rounded-full bg-orange-200 border border-orange-300"></div>
          <span class="text-[10px] uppercase tracking-widest font-sans font-bold text-stone-600">Tastes</span>
        </div>
      </div>
    </div>

    <!-- Graph Container -->
    <div id="graph" class="w-full h-full cursor-grab active:cursor-grabbing"></div>
  </main>
</BaseLayout>

<script is:inline src="https://unpkg.com/force-graph"></script>
<script define:vars={{ data }}>
  const container = document.getElementById('graph');
  const panel = document.getElementById('detail-panel');
  const pType = document.getElementById('panel-type');
  const pTitle = document.getElementById('panel-title');
  const pSub = document.getElementById('panel-sub');
  const pDesc = document.getElementById('panel-desc');
  const pMeta = document.getElementById('panel-meta');
  const pkmnContainer = document.getElementById('pokemon-container');
  const pkmnImg = document.getElementById('pokemon-img');
  const pkmnBg = document.getElementById('pokemon-bg');
  
  let selectedNode = null;
  const highlightNodes = new Set();
  const highlightLinks = new Set();

  const colors = {
    thought: '#ea580c',
    project: '#1c1917',
    taste: '#fed7aa',
  };

  function updatePanel(node) {
    const color = colors[node.type];
    pType.textContent = node.type;
    pType.style.color = color === '#1c1917' ? '#78716c' : color;
    pTitle.textContent = node.name;
    pSub.textContent = node.sub;
    pDesc.textContent = `"${node.desc}"`;
    pMeta.textContent = node.meta || '';

    if (node.sub === 'pokemon' && node.pid) {
      const spriteUrl = `https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/${node.pid}.png`;
      pkmnImg.src = spriteUrl;
      pkmnImg.alt = node.name;
      pkmnContainer.style.display = 'flex';
      pkmnBg.innerHTML = `<img src="${spriteUrl}" class="w-48 h-48 pixelated" />`;
    } else {
      pkmnContainer.style.display = 'none';
      pkmnBg.innerHTML = '';
    }

    document.body.style.backgroundColor = `${color}15`;
    panel.classList.remove('translate-x-12', 'opacity-0');
    panel.classList.add('translate-x-0', 'opacity-100');
  }

  function hidePanel() {
    if (selectedNode) return;
    document.body.style.backgroundColor = '';
    panel.classList.add('translate-x-12', 'opacity-0');
    panel.classList.remove('translate-x-0', 'opacity-100');
  }

  function updateHighlights(node) {
    highlightNodes.clear();
    highlightLinks.clear();
    if (node) {
      highlightNodes.add(node);
      data.links.forEach(link => {
        if (link.source.id === node.id || link.target.id === node.id) {
          highlightLinks.add(link);
          highlightNodes.add(link.source);
          highlightNodes.add(link.target);
        }
      });
    }
    Graph.nodeColor(Graph.nodeColor())
         .linkWidth(Graph.linkWidth())
         .linkDirectionalParticles(Graph.linkDirectionalParticles());
  }

  const Graph = ForceGraph()(container)
    .graphData(data)
    .nodeId('id')
    .nodeLabel(node => '') 
    .nodeColor(node => {
      if (highlightNodes.size > 0 && !highlightNodes.has(node)) {
        return 'rgba(28, 25, 23, 0.1)'; 
      }
      return colors[node.type];
    })
    .nodeRelSize(12)
    .linkWidth(link => highlightLinks.has(link) ? 3 : 1.5)
    .linkColor(link => highlightLinks.has(link) ? '#ea580c' : 'rgba(124, 45, 18, 0.1)')
    .linkDirectionalParticles(link => highlightLinks.has(link) ? 4 : 2)
    .linkDirectionalParticleSpeed(0.005)
    .linkDirectionalParticleWidth(link => highlightLinks.has(link) ? 4 : 2)
    .linkDirectionalParticleColor(() => '#ea580c')
    .onNodeClick(node => {
      if (selectedNode === node) {
        selectedNode = null;
        hidePanel();
      } else {
        selectedNode = node;
        updatePanel(node);
        updateHighlights(node);
      }
    })
    .onBackgroundClick(() => {
      selectedNode = null;
      hidePanel();
      updateHighlights(null);
    })
    .onNodeHover(node => {
      if (selectedNode) {
        container.style.cursor = node ? 'pointer' : 'grab';
        return;
      }
      
      if (node) {
        updatePanel(node);
        updateHighlights(node);
      } else {
        hidePanel();
        updateHighlights(null);
      }
      container.style.cursor = node ? 'pointer' : 'grab';
    })
    .backgroundColor('rgba(0,0,0,0)');

  Graph.d3Force('charge').strength(-150);
  Graph.d3Force('link').distance(100);
  Graph.d3Force('center', d3.forceCenter());
  Graph.d3Force('x', d3.forceX().strength(0.3));
  Graph.d3Force('y', d3.forceY().strength(0.3));

  window.addEventListener('resize', () => {
    Graph.width(window.innerWidth);
    Graph.height(window.innerHeight - 80);
  });
</script>

<style is:global>
  .graph-tooltip {
    display: none !important;
  }
  .pixelated {
    image-rendering: pixelated;
  }
</style>
