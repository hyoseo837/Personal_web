---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/projects';
import { thoughts } from '../data/thoughts';
import { tastes } from '../data/tastes';
import { links } from '../data/links';

// Prepare nodes
const nodes = [
  ...thoughts.map(t => ({ 
    id: t.id, 
    name: t.title, 
    type: 'thought', 
    desc: t.description, 
    sub: t.category, 
    meta: t.date 
  })),
  ...projects.map(p => ({ 
    id: p.id, 
    name: p.title, 
    type: 'project', 
    desc: p.description, 
    sub: p.stack 
  })),
  ...tastes.map(t => ({ 
    id: t.id, 
    name: t.name, 
    type: 'taste', 
    desc: t.description, 
    sub: t.category, 
    meta: t.creator,
    pid: t.pid
  }))
];

const graphLinks = links.map(l => ({
  source: l.from,
  target: l.to,
  reason: l.reason
}));

tastes.forEach(taste => {
  if (taste.connections) {
    taste.connections.forEach(connName => {
      const target = tastes.find(t => t.name === connName);
      if (target) {
        const exists = graphLinks.some(l => 
          (l.source === taste.id && l.target === target.id) || 
          (l.source === target.id && l.target === taste.id)
        );
        if (!exists) {
          graphLinks.push({
            source: taste.id,
            target: target.id,
            reason: 'Shared taste'
          });
        }
      }
    });
  }
});

const data = { nodes, links: graphLinks };
---

<BaseLayout title="Mind Graph">
  <main class="w-full h-[calc(100vh-80px)] relative overflow-hidden bg-stone-50">
    
    <!-- Header Info -->
    <div class="absolute top-12 left-12 z-10 pointer-events-none">
      <div class="flex items-center gap-4 mb-4">
        <div class="w-12 h-px bg-orange-900/30"></div>
        <span class="text-xs uppercase tracking-[0.3em] text-orange-900/60 font-sans font-semibold">The Pattern Web —</span>
      </div>
      <h1 class="text-4xl text-stone-900 font-serif tracking-tight">Mind Graph</h1>
    </div>

    <!-- Detail Panel (Right Side) -->
    <div 
      id="detail-panel" 
      class="absolute top-12 right-12 z-20 w-80 translate-x-12 opacity-0 pointer-events-none transition-all duration-500 ease-out"
    >
      <div class="bg-stone-900/90 backdrop-blur-xl p-8 rounded-[2.5rem] border border-white/10 shadow-2xl overflow-hidden relative group">
        <div id="pokemon-bg" class="absolute -right-4 -bottom-4 opacity-10 pointer-events-none grayscale brightness-200"></div>

        <div id="panel-type" class="text-[10px] uppercase tracking-[0.3em] text-orange-400 font-sans font-bold mb-4"></div>
        
        <div id="pokemon-container" class="hidden justify-center mb-6">
          <img id="pokemon-img" src="" alt="" class="w-32 h-32 pixelated drop-shadow-[0_0_15px_rgba(255,255,255,0.2)]" />
        </div>

        <h2 id="panel-title" class="text-2xl text-white font-serif leading-tight mb-4 tracking-tight"></h2>
        <div id="panel-sub" class="text-[10px] uppercase tracking-widest text-stone-400 font-sans font-bold mb-6 pb-6 border-b border-white/5"></div>
        <p id="panel-desc" class="text-stone-300 font-serif italic text-lg leading-relaxed"></p>
        
        <div id="panel-meta" class="mt-8 text-[9px] uppercase tracking-widest text-stone-500 font-sans font-bold"></div>
      </div>
    </div>

    <!-- Legend -->
    <div class="absolute bottom-12 left-12 z-10 bg-white/50 backdrop-blur-md p-6 rounded-3xl border border-stone-200/50 shadow-sm">
      <div class="flex flex-col gap-4">
        <div class="flex items-center gap-3">
          <div class="w-3 h-3 rounded-full bg-orange-600 shadow-[0_0_10px_rgba(234,88,12,0.4)]"></div>
          <span class="text-[10px] uppercase tracking-widest font-sans font-bold text-stone-600">Thoughts</span>
        </div>
        <div class="flex items-center gap-3">
          <div class="w-3 h-3 rounded-full bg-stone-800 shadow-[0_0_10px_rgba(28,25,23,0.3)]"></div>
          <span class="text-[10px] uppercase tracking-widest font-sans font-bold text-stone-600">Projects</span>
        </div>
        <div class="flex items-center gap-3">
          <div class="w-3 h-3 rounded-full bg-orange-200 border border-orange-300"></div>
          <span class="text-[10px] uppercase tracking-widest font-sans font-bold text-stone-600">Tastes</span>
        </div>
      </div>
    </div>

    <!-- Graph Container -->
    <div id="graph" class="w-full h-full cursor-grab active:cursor-grabbing" data-graph={JSON.stringify(data)}></div>
  </main>
</BaseLayout>

<script is:inline src="https://unpkg.com/force-graph"></script>
<script src="../scripts/mind-graph.ts"></script>

<style is:global>
  .graph-tooltip {
    display: none !important;
  }
  .pixelated {
    image-rendering: pixelated;
  }
</style>
