---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllPosts, getSlugFromId, formatDate } from '../../utils/posts';

const sortedPosts = await getAllPosts();
---

<BaseLayout 
	title="Archive" 
	description="A collection of distilled thoughts, technical patterns, and TILs by Hyoseo Lee."
>
	<div class="max-w-3xl mx-auto px-6 md:px-8 pt-16 md:pt-20 pb-10 md:pb-16">
		<header class="mb-20 md:mb-24">
			<div class="flex items-center gap-4 mb-8">
				<div class="w-8 md:w-12 h-px bg-orange-900/30"></div>
				<span class="label-xs !text-orange-900/60 tracking-[0.3em]">Distilled Thoughts —</span>
			</div>
			<h1 class="text-4xl sm:text-5xl md:text-7xl font-serif text-stone-900 leading-[1.1] tracking-tight mb-6">
				Archive<span class="text-stone-300 mx-4 font-light">/</span>
			</h1>
			<p class="mt-8 text-stone-500 font-serif italic text-xl md:text-2xl max-w-2xl leading-relaxed">
				The complete collection of distilled thoughts and technical patterns.
			</p>
		</header>

		
		<div class="grid grid-cols-1 gap-8">
			{sortedPosts.length > 0 ? sortedPosts.map((post) => (
				<article class="soft-block group">
					<div class="flex flex-col md:flex-row md:items-start gap-8">
						<div class="flex-grow">
							<div class="flex items-center gap-4 mb-6">
								<time class="label-xs text-stone-400 tabular-nums">
									{formatDate(post.data.date)}
								</time>
								<div class="w-1 h-1 bg-stone-200 rounded-full"></div>
								<a href={`/blog/${post.data.category}`} class="label-xs hover:text-orange-900 transition-colors">
									{post.data.category}
								</a>
							</div>
							
							<h2 class="text-3xl font-serif font-bold text-stone-900 mb-4 group-hover:text-orange-900 transition-colors leading-tight">
								<a href={`/blog/${getSlugFromId(post.id)}`}>
									{post.data.title}
								</a>
							</h2>
							
							<div class="flex flex-wrap gap-x-6 gap-y-2 mb-6 text-sm">
								<div class="flex items-center gap-2">
									<span class="label-xs !text-stone-300">Topic</span>
									<span class="font-serif italic text-stone-600">{post.data.topic}</span>
								</div>
								<div class="flex items-center gap-2">
									<span class="label-xs !text-stone-300">Area</span>
									<span class="font-serif italic text-stone-600">{post.data.area}</span>
								</div>
							</div>

							{post.data.summary && (
								<p class="text-stone-500 leading-relaxed font-serif text-lg mb-8 max-w-2xl">
									{post.data.summary}
								</p>
							)}

							<div class="flex flex-wrap gap-2">
								{post.data.tags.map((tag) => (
									<span class="px-3 py-1 bg-stone-100 text-stone-500 text-[10px] font-bold uppercase tracking-widest rounded-lg group-hover:bg-white transition-colors">
										#{tag}
									</span>
								))}
							</div>
						</div>
					</div>
				</article>
			)) : (
				<div class="py-20 text-center soft-block">
					<p class="text-stone-400 font-serif italic text-xl">The archive is currently quiet.</p>
					<p class="mt-2 text-stone-300 label-xs">New distilled thoughts will appear here soon.</p>
				</div>
			)}
		</div>
	</div>
</BaseLayout>
