---
import { links } from '../data/links';
import { thoughts } from '../data/thoughts';
import { projects } from '../data/projects';
import { tastes } from '../data/tastes';
import { Link as LinkIcon, Sparkles, Box, Heart } from 'lucide-astro';

interface Props {
  id: string;
}

const { id } = Astro.props;

const relevantLinks = links.filter(link => link.from === id || link.to === id);

const getDetails = (linkId: string) => {
  const thought = thoughts.find(t => t.id === linkId);
  if (thought) return { title: thought.title, type: 'Thought', icon: Sparkles, url: '/thinking' };
  
  const project = projects.find(p => p.id === linkId);
  if (project) return { title: project.title, type: 'Project', icon: Box, url: '/projects' };
  
  const taste = tastes.find(t => t.id === linkId);
  if (taste) return { title: taste.name, type: 'Taste', icon: Heart, url: '/about' };
  
  return null;
};
---

{relevantLinks.length > 0 && (
  <div class="flex items-center gap-2.5">
    <LinkIcon class="w-3 h-3 text-accent-muted/60 shrink-0" />
    
    <div class="flex gap-1.5">
      {relevantLinks.map(link => {
        const otherId = link.from === id ? link.to : link.from;
        const details = getDetails(otherId);
        if (!details) return null;
        const Icon = details.icon;
        
        return (
          <div class="group relative">
            <a 
              href={details.url}
              class="flex items-center justify-center w-6 h-6 rounded-full bg-surface/50 border border-border-dim text-accent-muted/70 hover:border-accent/40 hover:text-accent hover:bg-surface-hover transition-all duration-300"
            >
              <Icon class="w-3 h-3" />
            </a>

            <!-- Tooltip -->
            <div class="absolute bottom-full right-0 mb-3 w-48 p-4 bg-stone-900 text-white rounded-2xl text-[11px] opacity-0 group-hover:opacity-100 transition-all duration-300 pointer-events-none z-50 shadow-2xl translate-y-2 group-hover:translate-y-0">
              <div class="flex flex-col gap-2">
                <div class="flex justify-between items-start">
                  <span class="font-sans font-bold uppercase tracking-widest text-[8px] text-white/40">
                    {details.type}
                  </span>
                  <span class="font-sans font-bold uppercase tracking-widest text-[8px] text-accent-bright/60">
                    Click to view
                  </span>
                </div>
                
                <p class="font-serif text-[12px] text-white font-medium leading-tight">
                  {details.title}
                </p>

                {link.reason && (
                  <p class="font-serif italic text-[11px] text-white/70 leading-relaxed border-t border-white/10 pt-2 mt-1">
                    "{link.reason}"
                  </p>
                )}
              </div>
              
              <!-- Tooltip Arrow -->
              <div class="absolute top-full right-3 -mt-px border-8 border-transparent border-t-stone-900"></div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
)}
