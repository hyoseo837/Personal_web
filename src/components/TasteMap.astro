---
import { tastes } from '../data/tastes';
import { Heart } from 'lucide-astro';

const categories = [
  { id: 'books', label: 'Books', color: 'bg-stone-500', hex: '#78716c', creatorLabel: 'Author' },
  { id: 'films', label: 'Films', color: 'bg-orange-500', hex: '#f97316', creatorLabel: 'Director' },
  { id: 'games', label: 'Games', color: 'bg-amber-500', hex: '#f59e0b', creatorLabel: 'Studio' },
  { id: 'music', label: 'Music', color: 'bg-rose-500', hex: '#f43f5e', creatorLabel: 'Artist' },
  { id: 'pokemon', label: 'Pokémon', color: 'bg-teal-500', hex: '#14b8a6' },
];

const groupedTastes = categories.map(cat => ({
  ...cat,
  items: tastes.filter(item => item.category === cat.id)
}));
---

<div class="soft-block relative" id="taste-map-container">
  <!-- Connection Lines SVG Overlay -->
  <svg 
    id="connections-svg" 
    class="absolute inset-0 w-full h-full pointer-events-none z-0"
    style="overflow: visible;"
  >
  </svg>

  <!-- Header inside the box -->
  <div class="relative z-10 flex items-center gap-4 mb-12">
    <div class="icon-box">
      <Heart class="w-6 h-6" />
    </div>
    <div>
      <h2 class="text-2xl heading-serif">Taste Map</h2>
      <p class="label-xs">
        A curated collection of influences
      </p>
    </div>
  </div>

  <div class="relative z-10 grid grid-cols-1 md:grid-cols-2 gap-y-12 gap-x-16">
    {groupedTastes.map(group => (
      <div class="group/cat">
        <div class="flex items-center gap-3 mb-6">
          <div class={`w-2 h-2 rounded-full ${group.color} opacity-40 group-hover/cat:opacity-100 transition-opacity`}></div>
          <h3 class="label-xs text-text-main font-bold">
            {group.label}
          </h3>
        </div>
        
        <div class="flex flex-wrap gap-x-3 gap-y-3">
          {group.items.map(item => (
            <div 
              class="group relative taste-item" 
              data-name={item.name}
              data-color={group.hex}
              data-connections={JSON.stringify(item.connections || [])}
            >
              <span class="inline-flex items-center px-3 py-1.5 rounded-xl bg-surface/60 border border-border-dim text-[13px] text-text-muted font-serif hover:bg-surface-hover hover:border-border-hover hover:text-text-main transition-all duration-300 cursor-default">
                {item.name}
              </span>
              
              <!-- Minimalist Tooltip -->
              <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-3 w-56 p-4 bg-stone-900 text-white rounded-2xl text-[11px] opacity-0 group-hover:opacity-100 transition-all duration-300 pointer-events-none z-50 shadow-2xl translate-y-2 group-hover:translate-y-0">
                <div class="flex flex-col gap-2">
                  <div class="flex justify-between items-start">
                    <span class="font-sans font-bold uppercase tracking-widest text-[8px] text-white/40">
                      {group.label}
                    </span>
                    {item.creator && (
                      <span class="font-sans font-bold uppercase tracking-widest text-[8px] text-orange-200/60">
                        {group.creatorLabel}: {item.creator}
                      </span>
                    )}
                  </div>

                  {item.category === 'pokemon' && item.id && (
                    <div class="flex justify-center -my-2">
                      <img 
                        src={`https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/${item.id}.png`} 
                        alt={item.name}
                        class="w-24 h-24 pixelated drop-shadow-[0_0_8px_rgba(255,255,255,0.2)]"
                      />
                    </div>
                  )}
                  
                  <p class="font-serif italic text-[12px] text-white/90 leading-relaxed">
                    "{item.description}"
                  </p>
                </div>
                
                <!-- Tooltip Arrow -->
                <div class="absolute top-full left-1/2 -translate-x-1/2 -mt-px border-8 border-transparent border-t-stone-900"></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .pixelated {
    image-rendering: pixelated;
  }
</style>

<script>
  const items = document.querySelectorAll('.taste-item');
  const body = document.body;
  const container = document.getElementById('taste-map-container');
  const svg = document.getElementById('connections-svg');

  function drawLine(x1, y1, x2, y2, color) {
    if (!svg) return;
    const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    
    // Create a curved path
    const dx = x2 - x1;
    const dy = y2 - y1;
    const cx1 = x1 + dx * 0.2;
    const cy1 = y1 + dy * 0.8;
    const cx2 = x1 + dx * 0.8;
    const cy2 = y1 + dy * 0.2;
    
    const d = `M ${x1} ${y1} C ${cx1} ${cy1}, ${cx2} ${cy2}, ${x2} ${y2}`;
    
    path.setAttribute('d', d);
    path.setAttribute('stroke', color);
    path.setAttribute('stroke-width', '1.5');
    path.setAttribute('fill', 'none');
    path.setAttribute('stroke-dasharray', '1000');
    path.setAttribute('stroke-dashoffset', '1000');
    path.classList.add('connection-line');
    
    svg.appendChild(path);
    
    // Trigger animation
    requestAnimationFrame(() => {
      path.style.transition = 'stroke-dashoffset 0.8s ease-out, opacity 0.3s ease-out';
      path.style.strokeDashoffset = '0';
      path.style.opacity = '0.3';
    });
  }

  items.forEach(item => {
    item.addEventListener('mouseenter', () => {
      const color = item.getAttribute('data-color');
      const connections = JSON.parse(item.getAttribute('data-connections') || '[]');
      
      if (color) {
        body.style.backgroundColor = `${color}0D`; 
        if (container) container.style.borderColor = `${color}40`;
      }

      if (connections.length > 0 && svg && container) {
        const rect1 = item.getBoundingClientRect();
        const containerRect = container.getBoundingClientRect();
        const x1 = rect1.left - containerRect.left + rect1.width / 2;
        const y1 = rect1.top - containerRect.top + rect1.height / 2;

        connections.forEach(targetName => {
          const target = document.querySelector(`.taste-item[data-name="${targetName}"]`);
          if (target) {
            const rect2 = target.getBoundingClientRect();
            const x2 = rect2.left - containerRect.left + rect2.width / 2;
            const y2 = rect2.top - containerRect.top + rect2.height / 2;
            
            drawLine(x1, y1, x2, y2, color || '#000');
            target.querySelector('span').classList.add('!border-accent-bright', '!text-text-main');
          }
        });
      }
    });

    item.addEventListener('mouseleave', () => {
      body.style.backgroundColor = '';
      if (container) container.style.borderColor = '';
      
      if (svg) {
        const lines = svg.querySelectorAll('.connection-line');
        lines.forEach(line => {
          line.style.opacity = '0';
          setTimeout(() => line.remove(), 300);
        });
      }

      document.querySelectorAll('.taste-item span').forEach(span => {
        span.classList.remove('!border-accent-bright', '!text-text-main');
      });
    });
  });
</script>
