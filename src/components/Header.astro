---
const pathname = new URL(Astro.request.url).pathname;
---

<header class="w-full px-8 pt-10 flex justify-between items-center">
  <a href="/" class="text-xl text-stone-900 font-serif font-bold tracking-tight hover:text-orange-900 transition-colors">
    Hyoseo
  </a>
  
  <nav class="flex gap-8 font-sans font-bold text-[10px] uppercase tracking-[0.2em]">
    {[
      { name: 'About', href: '/about' },
      { name: 'Thinking', href: '/thinking' },
      { name: 'Projects', href: '/projects' },
      { name: 'Graph', href: '/graph' }
    ].map((item) => {
      const isActive = pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href));
      return (
        <a 
          href={item.href} 
          class:list={[
            "transition-colors duration-300",
            isActive ? "text-orange-900" : "text-stone-400 hover:text-stone-900"
          ]}
        >
          {item.name}
        </a>
      );
    })}
  </nav>
</header>